      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRED-005",
      "name": "Keyring / wallet access",
      "severity": "critical",
      "category": "credential_theft",
      "description": "Reads OS keyrings (gnome-keyring/kwallet/secret-tool) or crypto wallet files (electrum/bitcoin/metamask/keystore).",
      "recommendation": "Do not build. This harvests secrets/wallets.",
      "cwe": "CWE-522",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRED-008",
      "name": "Environment/secret dump",
      "severity": "high",
      "category": "credential_theft",
      "description": "Dumping the environment (env/printenv) to a file or pipe to curl/nc/base64 — harvests tokens and secrets exposed as env vars.",
      "recommendation": "Remove. Packages have no reason to dump the environment.",
      "cwe": "CWE-522",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRYPTO-001",
      "name": "Mining pool connection",
      "severity": "critical",
      "category": "cryptomining",
      "description": "Connection to cryptocurrency mining pools",
      "recommendation": "Remove cryptomining components",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRYPTO-002",
      "name": "Cryptominer binary",
      "severity": "critical",
      "category": "cryptomining",
      "description": "Known cryptocurrency miner executable names",
      "recommendation": "Remove cryptomining components",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRYPTO-003",
      "name": "Monero/Bitcoin wallet address",
      "severity": "critical",
      "category": "cryptomining",
      "description": "Cryptocurrency wallet addresses indicate mining or theft",
      "recommendation": "Wallet addresses in packages are highly suspicious",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "DEEP-001",
      "name": "Decode-and-execute flow",
      "severity": "critical",
      "category": "obfuscation",
      "description": "The file decodes/decompresses data and dynamically executes shell input, possibly across lines.",
      "recommendation": "Decode and review the payload manually.",
      "cwe": "CWE-506",
      "owner": "deep",
      "pattern_based": false
    },
    {
      "id": "DEEP-002",
      "name": "Large embedded encoded blob",
      "severity": "high",
      "category": "obfuscation",
      "description": "A large base64-like blob is embedded in the package.",
      "recommendation": "Decode and verify the blob is legitimate data.",
      "cwe": "CWE-506",
      "owner": "deep",
      "pattern_based": false
    },
    {
      "id": "DEP-001",
      "name": "Provides a core package name (dependency confusion)",
      "severity": "high",
      "category": "suspicious_metadata",
      "description": "provides= a curated core package name from a package that is not that package's own alternate, satisfying a dependency in its place.",
      "recommendation": "Remove the provides unless this is the legitimate provider.",
      "cwe": "CWE-427",
      "owner": "metadata",
      "pattern_based": false
    },
    {
      "id": "DEP-003",
      "name": "Package index/registry override",
      "severity": "high",
      "category": "dependencies",
      "description": "Redirects a language package manager to a non-default index/registry (pip --index-url, npm registry, GOPROXY, etc.) — a dependency-confusion vector.",
      "recommendation": "Verify the index host; overriding the registry redirects dependencies to an attacker source.",
      "cwe": "CWE-494",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "DLE-001",
      "name": "Curl pipe to shell",
      "severity": "critical",
      "category": "command_injection",
      "description": "Downloading and executing remote scripts is extremely dangerous. Used in 2018 xeactor attack.",
      "recommendation": "Download scripts first, review them, then execute",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "DLE-002",
      "name": "Wget pipe to shell",
      "severity": "critical",
      "category": "command_injection",
      "description": "Downloading and executing remote scripts via wget",
      "recommendation": "Download scripts first, review them, then execute",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "DLE-003",
      "name": "Curl output executed",
      "severity": "critical",
      "category": "command_injection",
      "description": "Curl output saved and executed - common malware pattern",
      "recommendation": "Review downloaded scripts before execution",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "ENV-001",
      "name": "LD_PRELOAD manipulation",
      "severity": "critical",
      "category": "malicious_code",
      "description": "LD_PRELOAD can be used to inject malicious libraries",
      "recommendation": "LD_PRELOAD manipulation is extremely suspicious",
      "cwe": "CWE-426",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "ENV-002",
      "name": "PATH manipulation",
      "severity": "high",
      "category": "malicious_code",
      "description": "Modifying PATH to hijack commands",
      "recommendation": "PATH manipulation in install scripts is suspicious",
      "cwe": "CWE-426",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "ENV-003",
      "name": "Bashrc/profile modification",
      "severity": "critical",
      "category": "persistence",
      "description": "Modifying shell config for persistence",
      "recommendation": "Packages should not modify shell configuration",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXAMPLE-001",
      "name": "Example: references example.com",
      "severity": "info",
      "category": "configuration",
      "description": "Demonstration rule. Flags any source/command that references example.com.",
      "recommendation": "This is only an example rule; delete or replace it.",
      "cwe": null,
      "owner": "user",
      "pattern_based": true
    },
    {
      "id": "EXEC-002",
      "name": "Shell -c command substitution fetch",
      "severity": "critical",
      "category": "malicious_code",
      "description": "sh -c \"$(curl ...)\" — fetches and runs remote code without an explicit pipe, evading the curl|sh rules.",
      "recommendation": "Do not build. This runs code fetched from a URL.",
      "cwe": "CWE-494",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXEC-005",
      "name": "Detached background execution",
      "severity": "medium",
      "category": "malicious_code",
      "description": "Launches a fetched/dropped payload detached from the build (setsid/nohup), so it keeps running after install.",
      "recommendation": "Review the detached process; this outlives the install.",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXEC-006",
      "name": "sqlite3 shell-command execution",
      "severity": "high",
      "category": "malicious_code",
      "description": "sqlite3's `.shell`/`.system` dot-commands run an arbitrary shell command, and `.import` can read an attacker-controlled file — an exec/RCE vector hidden inside what looks like a database call. Legitimate packages do not drive sqlite3 through these meta-commands.",
      "recommendation": "Do not build. sqlite3 .shell/.system run arbitrary commands; report the package.",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXEC-007",
      "name": "make reads a Makefile from stdin",
      "severity": "high",
      "category": "command_injection",
      "description": "`make -f -` / `make -f /dev/stdin` executes a Makefile fed on standard input (commonly the tail of a `curl ... | make -f -` fetch-and-run). A Makefile is arbitrary shell recipes, so this is RCE from an unverified source. Normal `make` / `make -f Makefile` builds are unaffected.",
      "recommendation": "Review the Makefile source; building a Makefile read from stdin/a pipe runs unverified recipes.",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXEC-REMOTE",
      "name": "Fetches and runs external code",
      "severity": "critical",
      "category": "malicious_code",
      "description": "The package downloads and executes code from an external URL at build/install time; the scanner does not follow it (opaque boundary).",
      "recommendation": "Do not build; obtain software that ships its real code.",
      "cwe": "CWE-494",
      "owner": "remote_exec",
      "pattern_based": false
    },
    {
      "id": "EXFIL-001",
      "name": "Curl POST data exfiltration",
      "severity": "critical",
      "category": "data_exfiltration",
      "description": "Sending data to external servers via curl POST",
      "recommendation": "Build/install should not send data externally",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-002",
      "name": "Netcat data transfer",
      "severity": "critical",
      "category": "data_exfiltration",
      "description": "Using netcat to transfer data externally",
      "recommendation": "Netcat should not be piping data in build scripts",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-003",
      "name": "Discord/Telegram webhook",
      "severity": "critical",
      "category": "data_exfiltration",
      "description": "Webhook URLs can be used for C2 communication or data exfiltration",
      "recommendation": "Webhook URLs in packages are highly suspicious",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-004",
      "name": "DNS exfiltration",
      "severity": "critical",
      "category": "data_exfiltration",
      "description": "Data smuggled out via DNS lookups (dig/nslookup/host of a command-substituted subdomain, or a TXT query to an attacker domain).",
      "recommendation": "Review the destination domain; this pattern smuggles data over DNS.",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-006",
      "name": "HTTP upload exfiltration",
      "severity": "high",
      "category": "data_exfiltration",
      "description": "curl uploading a local file (-T/--upload-file/-F/--data-urlencode) — used to send harvested data to an attacker endpoint.",
      "recommendation": "Verify what is being uploaded and to where.",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-007",
      "name": "wget POST exfiltration",
      "severity": "high",
      "category": "data_exfiltration",
      "description": "wget --post-data/--post-file sending local data to a remote endpoint.",
      "recommendation": "Verify what is being posted and to where.",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-008",
      "name": "Slack/Teams webhook exfiltration",
      "severity": "critical",
      "category": "data_exfiltration",
      "description": "Posting to a Slack or Microsoft Teams incoming webhook — a common low-friction exfil/C2 channel.",
      "recommendation": "Remove. Packages do not post to chat webhooks during build/install.",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "EXFIL-009",
      "name": "Anonymous file-drop / tunnel host",
      "severity": "high",
      "category": "data_exfiltration",
      "description": "Uploads to a throwaway file-drop or tunnels through ngrok/webhook.site/requestbin/IPFS — exfil and ad-hoc C2 endpoints.",
      "recommendation": "Review the destination; these are common exfil/C2 hosts.",
      "cwe": "CWE-200",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "FUNC-001",
      "name": "Network access in a build function",
      "severity": "high",
      "category": "network_security",
      "description": "A build/package function performs network access (curl/wget/fetch); downloads belong in the source array.",
      "recommendation": "Move downloads to the source= array.",
      "cwe": null,
      "owner": "pattern",
      "pattern_based": false
    },
    {
      "id": "HIDDEN-001",
      "name": "Hidden file creation in home",
      "severity": "high",
      "category": "malicious_code",
      "description": "Creating hidden files in user home directory",
      "recommendation": "Packages should not create hidden files in user home",
      "cwe": null,
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "HIDDEN-002",
      "name": "Tmp directory execution",
      "severity": "high",
      "category": "malicious_code",
      "description": "Executing from /tmp is suspicious. CHAOS RAT placed binary in /tmp.",
      "recommendation": "Packages should not execute from /tmp",
      "cwe": null,
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "HIDDEN-003",
      "name": "Binary in non-standard location",
      "severity": "high",
      "category": "malicious_code",
      "description": "Placing binaries in /usr/local/share or ~/.local/share. Used by CHAOS RAT.",
      "recommendation": "Binaries should be placed in standard locations",
      "cwe": null,
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "INSTALL-001",
      "name": "Python execution in install script",
      "severity": "critical",
      "category": "malicious_code",
      "description": "Executing Python in post_install is suspicious. Used in July 2025 CHAOS RAT attack.",
      "recommendation": "Install scripts should not execute Python code",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "INSTALL-002",
      "name": "Binary execution in install script",
      "severity": "high",
      "category": "malicious_code",
      "description": "Executing binaries from /opt or package directories during install",
      "recommendation": "Review any binary execution during installation",
      "cwe": "CWE-94",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "INSTALL-003",
      "name": "Network access in install script",
      "severity": "critical",
      "category": "network_security",
      "description": "Install scripts should not make network connections",
      "recommendation": "Install scripts should never download additional content",
      "cwe": "CWE-494",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "INSTALL-004",
      "name": "Language package manager invoked in install hook",
      "severity": "critical",
      "category": "malicious_code",
      "description": "An install scriptlet invokes a language package manager to fetch/install packages. Installing a package runs its arbitrary build/lifecycle scripts (preinstall, build.rs, setup.py, go generate, ...) at install time -- a remote code execution vector. The June 2026 Atomic Arch campaign used `npm install` this way (see ATOMIC-002); the same applies to pip, poetry, uv, pdm, cargo, go, gem, composer, conda, deno, and others.",
      "recommendation": "Install hooks must never fetch or install packages. Declare real dependencies in depends/makedepends and handle sources in the source= array; report the package to the AUR maintainers.",
      "cwe": "CWE-494",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "IOC-001",
      "name": "Known indicator-of-compromise match",
      "severity": "critical",
      "category": "malicious_code",
      "description": "Content matches a known IOC (malicious npm/bun package, file artifact, or C2 domain).",
      "recommendation": "Do not build; treat the host as compromised if already built.",
      "cwe": "CWE-506",
      "owner": "ioc",
      "pattern_based": false
    },
    {
      "id": "META-001",
      "name": "Provides impersonation",
      "severity": "low",
      "category": "suspicious_metadata",
      "description": "Package provides another package name, may be impersonating. CHAOS RAT used this technique.",
      "recommendation": "Verify this package is a legitimate alternative",
      "cwe": null,
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "META-002",
      "name": "validpgpkeys declared but no signature verified",
      "severity": "low",
      "category": "suspicious_metadata",
      "description": "validpgpkeys= lists signing keys but no source carries a detached signature or ?signed fragment, so the key verifies nothing.",
      "recommendation": "Verify a signed source against the key, or remove the unused validpgpkeys.",
      "cwe": "CWE-347",
      "owner": "metadata",
      "pattern_based": false
    },
    {
      "id": "META-003",
      "name": "Replaces/conflicts a core or security package",
      "severity": "high",
      "category": "suspicious_metadata",
      "description": "replaces=/conflicts= forces pacman to displace an official (often security-critical) package with this AUR build.",
      "recommendation": "Remove unless this is the legitimate provider; report to the AUR maintainers.",
      "cwe": "CWE-1357",
      "owner": "metadata",
      "pattern_based": false
    },
    {
      "id": "META-004",
      "name": "epoch set (forces upgrade over the repo version)",
      "severity": "low",
      "category": "suspicious_metadata",
      "description": "epoch>=1 makes the package outrank the official version regardless of pkgver; escalates when combined with provides/replaces of a trusted name.",
      "recommendation": "Confirm the epoch is a real upstream versioning reset, not a stealth supersede.",
      "cwe": null,
      "owner": "metadata",
      "pattern_based": false
    },
    {
      "id": "META-005",
      "name": "install= points outside the package",
      "severity": "medium",
