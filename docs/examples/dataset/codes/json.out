{
  "entries": [
    {
      "id": "ATOMIC-001",
      "name": "Atomic Arch malicious npm/bun package",
      "severity": "critical",
      "category": "malicious_code",
      "description": "References a known-malicious package from the June 2026 'Atomic Arch' AUR supply-chain campaign (atomic-lockfile, js-digest, lockfile-js). These pull an infostealer and eBPF rootkit during the build/install phase.",
      "recommendation": "Do NOT build. This is a known-malicious dependency. Remove the package and treat the host as compromised: rotate credentials (SSH, npm/GitHub tokens, browser sessions).",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "ATOMIC-002",
      "name": "Node/Bun package manager in install hook",
      "severity": "critical",
      "category": "malicious_code",
      "description": "Invokes npm/pnpm/yarn/bun (or the npx/bunx runners) to install or run packages from an install hook. The June 2026 'Atomic Arch' campaign added post-install hooks running `npm install atomic-lockfile` / `bun install js-digest`. Legitimate packages never fetch or execute npm/bun packages during the install phase. `npm ci`, `npm rebuild`, `npm exec`, `pnpm dlx`, `yarn dlx`, and the bare `npx <pkg>` / `bunx <pkg>` runners all fetch-and-run lifecycle/remote code just like `install`.",
      "recommendation": "Install scripts must never fetch or install npm/bun packages. Inspect the PKGBUILD diff and report the package to the AUR maintainers.",
      "cwe": "CWE-494",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "ATOMIC-003",
      "name": "eBPF rootkit / payload artifact",
      "severity": "critical",
      "category": "persistence",
      "description": "References the eBPF rootkit object (scales.bpf.c) or the 'deps' hook path used by the June 2026 'Atomic Arch' payload to gain rootkit-like capabilities and hide itself.",
      "recommendation": "This is a rootkit dropper artifact. Do not build; treat the host as compromised and reinstall rather than clean.",
      "cwe": "CWE-506",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "BROWSER-001",
      "name": "Browser profile access",
      "severity": "critical",
      "category": "credential_theft",
      "description": "Accessing browser profiles may indicate credential theft",
      "recommendation": "Package should never access browser profiles",
      "cwe": "CWE-522",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "BROWSER-002",
      "name": "Browser database access",
      "severity": "critical",
      "category": "credential_theft",
      "description": "Accessing browser SQLite databases (passwords, cookies, history)",
      "recommendation": "Package should never access browser databases",
      "cwe": "CWE-522",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CHK-001",
      "name": "No checksums for sources",
      "severity": "high",
      "category": "cryptography",
      "description": "Package sources have no checksum verification.",
      "recommendation": "Provide sha256sums or stronger for every source.",
      "cwe": "CWE-354",
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CHK-002",
      "name": "MD5 checksums used",
      "severity": "medium",
      "category": "cryptography",
      "description": "MD5 is cryptographically broken.",
      "recommendation": "Replace md5sums with sha256sums or sha512sums.",
      "cwe": "CWE-328",
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CHK-003",
      "name": "SHA1 checksums used",
      "severity": "medium",
      "category": "cryptography",
      "description": "SHA1 is cryptographically weak.",
      "recommendation": "Replace sha1sums with sha256sums or sha512sums.",
      "cwe": "CWE-328",
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CHK-004",
      "name": "Some sources use SKIP checksum",
      "severity": "medium",
      "category": "cryptography",
      "description": "Some non-VCS sources skip integrity verification.",
      "recommendation": "Provide real checksums for non-VCS sources.",
      "cwe": "CWE-354",
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CHK-005",
      "name": "All non-VCS sources use SKIP",
      "severity": "high",
      "category": "cryptography",
      "description": "No integrity verification is performed on any non-VCS source.",
      "recommendation": "Provide real checksums for non-VCS sources.",
      "cwe": "CWE-354",
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CHK-006",
      "name": "Checksum count mismatch",
      "severity": "high",
      "category": "configuration",
      "description": "The number of checksums does not match the number of sources.",
      "recommendation": "Align the checksum array with the source array.",
      "cwe": null,
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CHK-008",
      "name": "Malformed or wrong-length checksum",
      "severity": "medium",
      "category": "cryptography",
      "description": "A checksum is not valid hex of the algorithm's expected length (md5=32, sha1=40, sha256=64, sha512/b2=128).",
      "recommendation": "Regenerate checksums with updpkgsums; a malformed hash silently disables integrity verification.",
      "cwe": "CWE-354",
      "owner": "checksum",
      "pattern_based": false
    },
    {
      "id": "CRED-001",
