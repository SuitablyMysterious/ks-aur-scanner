      "description": "Accessing SSH private keys during build/install",
      "recommendation": "Package should never access user SSH keys",
      "cwe": "CWE-522",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRED-002",
      "name": "GPG key access",
      "severity": "critical",
      "category": "credential_theft",
      "description": "Accessing GPG keyring during build/install",
      "recommendation": "Package should never access user GPG keys",
      "cwe": "CWE-522",
      "owner": "rules",
