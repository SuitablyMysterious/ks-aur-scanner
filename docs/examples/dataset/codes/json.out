    },
    {
      "id": "CRED-003",
      "name": "Password file access",
      "severity": "critical",
      "category": "credential_theft",
      "description": "Accessing password files or credential stores",
      "recommendation": "Package should never access credential stores",
      "cwe": "CWE-522",
      "owner": "rules",
      "pattern_based": true
    },
    {
      "id": "CRED-004",
      "name": "Cloud / CI credential file access",
      "severity": "high",
      "category": "credential_theft",
      "description": "Reads cloud or CI credential files (gcloud, docker config, npmrc, pypirc, cargo/terraform credentials, git-credentials).",
      "recommendation": "Verify why a build/install touches credential files.",
