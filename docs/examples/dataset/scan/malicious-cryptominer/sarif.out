            {
              "defaultConfiguration": {
                "level": "warning"
              },
              "fullDescription": {
                "text": "One or more checksums are not valid hex of the expected length, so they cannot match the source and integrity verification is effectively disabled: md5sums has a bad entry 'abc123…' (len 6)."
              },
              "help": {
                "text": "Regenerate the checksums with updpkgsums; a malformed hash silently disables integrity verification."
              },
              "id": "CHK-008",
              "name": "Malformed or wrong-length checksum",
              "shortDescription": {
                "text": "Malformed or wrong-length checksum"
