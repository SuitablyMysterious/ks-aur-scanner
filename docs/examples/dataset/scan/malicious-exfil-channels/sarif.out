              "shortDescription": {
                "text": "Hidden file creation in home (install script)"
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "curl uploading a local file (-T/--upload-file/-F/--data-urlencode) — used to send harvested data to an attacker endpoint."
              },
              "help": {
                "text": "Verify what is being uploaded and to where."
              },
              "id": "EXFIL-006",
              "name": "HTTP upload exfiltration (install script)",
              "shortDescription": {
                "text": "HTTP upload exfiltration (install script)"
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Uploads to a throwaway file-drop or tunnels through ngrok/webhook.site/requestbin/IPFS — exfil and ad-hoc C2 endpoints."
              },
              "help": {
                "text": "Review the destination; these are common exfil/C2 hosts."
