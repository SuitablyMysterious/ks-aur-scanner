            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
                "text": "Posting to a Slack or Microsoft Teams incoming webhook — a common low-friction exfil/C2 channel."
              },
              "help": {
                "text": "Remove. Packages do not post to chat webhooks during build/install."
              },
              "id": "EXFIL-008",
              "name": "Slack/Teams webhook exfiltration (install script)",
              "shortDescription": {
                "text": "Slack/Teams webhook exfiltration (install script)"
              }
            },
            {
              "defaultConfiguration": {
                "level": "error"
              },
              "fullDescription": {
